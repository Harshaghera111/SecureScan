# ── SecureScan Backend Environment Variables ──

# Application
APP_NAME=SecureScan
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Database
DATABASE_URL=postgresql+asyncpg://securescan:securescan@localhost:5432/securescan

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=mock

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
